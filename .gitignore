.DS_Store

# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Local environment files
.env
.env.*
!.env.example

# Logs and coverage
*.log
coverage/

# TypeScript and build cache
*.tsbuildinfo
.turbo/

