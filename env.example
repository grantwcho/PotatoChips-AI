# Core Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-east1
GOOGLE_CLOUD_SERVICE=gpt-capital-web

# Submission intake auth + storage
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
STORAGE_BASE_PATH=./storage
SUBMISSIONS_VIRUS_SCAN_ENABLED=false
SUBMISSIONS_VIRUS_SCAN_REQUIRED=false
SUBMISSIONS_CLAMAV_HOST=
SUBMISSIONS_CLAMAV_PORT=3310
SUBMISSIONS_CLAMAV_TIMEOUT_MS=20000

# Identity Platform
IDENTITY_PLATFORM_PROJECT_ID=
IDENTITY_PLATFORM_TENANT_ID=
IDENTITY_PLATFORM_API_KEY=

# Local dashboard bypass. Only honored during `npm run dev`.
# Set to `true` to open `/dashboard` locally without signing in.
DEV_DASHBOARD_BYPASS=false
DEV_DASHBOARD_BYPASS_EMAIL=local-investor@potatochipsai.dev
DEV_DASHBOARD_BYPASS_NAME=Local Investor
DEV_DASHBOARD_BYPASS_ID=dev-local-investor

# Submission intake database (Prisma)
# Local development can use SQLite:
DATABASE_URL=file:./prisma/dev.db

# AlloyDB / transactional data
# Set to `alloydb` after applying site/db/alloydb/001_initial_schema.sql.
APP_USER_STORE_BACKEND=firestore
ALLOYDB_DATABASE_URL=
ALLOYDB_INSTANCE=
ALLOYDB_DATABASE=
ALLOYDB_USER=
ALLOYDB_PASSWORD_SECRET=

# BigQuery / analytics and audit
BIGQUERY_PROJECT_ID=
BIGQUERY_LOCATION=US
BIGQUERY_RESEARCH_DATASET=
BIGQUERY_AUDIT_DATASET=
BIGQUERY_TELEMETRY_DATASET=

# Agent orchestration
AGENT_WORKER_SECRET=
AGENT_AUTONOMOUS_LOOP_ENABLED=false
AGENT_FORCE_ALL_IDLE=false
AGENT_FORCE_ALL_ACTIVE=false
PUBSUB_AGENT_EVENTS_TOPIC=
PUBSUB_TRADE_DECISIONS_TOPIC=
PUBSUB_RISK_ALERTS_TOPIC=
CLOUD_TASKS_AGENT_QUEUE=
CLOUD_TASKS_RISK_QUEUE=
WORKFLOWS_REBALANCE_NAME=
WORKFLOWS_INCIDENT_RESPONSE_NAME=

# Paper trading / broker connectivity
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Agent decision models
# Set at least one provider key before enabling AGENT_AUTONOMOUS_LOOP_ENABLED.
# Anthropic is the default primary route for Potato Chips AI's layered router:
# desk agents use Sonnet, while the CIO and AI HR use Opus.
AGENT_DECISION_PROVIDER=
AGENT_DECISION_OPENAI_MODEL=gpt-4.1
AGENT_DECISION_ANTHROPIC_MODEL=claude-sonnet-4-6
AGENT_DESK_OPENAI_MODEL=gpt-4.1
AGENT_DESK_ANTHROPIC_MODEL=claude-sonnet-4-6
AGENT_CIO_OPENAI_MODEL=gpt-4.1
AGENT_CIO_ANTHROPIC_MODEL=claude-opus-4-6
AGENT_MESSAGE_OPENAI_MODEL=gpt-4.1-mini
AGENT_MESSAGE_ANTHROPIC_MODEL=claude-sonnet-4-6
HR_AGENT_OPENAI_MODEL=gpt-4.1-mini
HR_AGENT_ANTHROPIC_MODEL=claude-opus-4-6
# Backward-compatible alias for older local setups. Prefer HR_AGENT_ANTHROPIC_MODEL.
HR_AGENT_CLAUDE_MODEL=
ENSEMBLE_ORCHESTRATOR_MODEL=claude-opus-4-7
AGENT_DECISION_TEMPERATURE=0.2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Python used for the built-in trading sleeves and backtesting.
# It must have the agent dependencies installed: numpy, pandas, PyYAML,
# and statsmodels for the stat-arb sleeve. `yfinance` is now optional and only
# needed if you intentionally leave it in the provider fallback chain below.
PYTHON_TRADING_AGENT_BIN=python3
GPTCAPITAL_AGENT_STATE_DIR=/tmp/gptcapital-agent-state
AGENT_MARKET_DATA_PROVIDERS=alpaca,alpha_vantage,yfinance

# Research market data
MASSIVE_ENDPOINT=https://api.massive.com
MASSIVE_API_KEY=
ALPHA_VANTAGE_ENDPOINT=https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=

# SEC EDGAR is keyless, but SEC fair-access policy asks automated clients to
# declare an organization/contact in the User-Agent header.
SEC_DATA_ENDPOINT=https://data.sec.gov
SEC_ARCHIVES_ENDPOINT=https://www.sec.gov
SEC_USER_AGENT=Potato Chips AI Research contact@example.com

# Security and secrets
SECRET_MANAGER_PREFIX=
LOG_SINK_DATASET=
VPC_SC_PERIMETER=

# Temporary Firestore compatibility block.
# Remove these once app_users and portfolio state have moved into AlloyDB.
FIRESTORE_COMPATIBILITY_PROJECT_ID=
FIRESTORE_COMPATIBILITY_CLIENT_EMAIL=
FIRESTORE_COMPATIBILITY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Backward-compatible aliases for older local setups. Prefer the
# FIRESTORE_COMPATIBILITY_* variables above for new environments.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
